---
/**
 * 文章侧边栏目录组件。
 *
 * 固定在右侧，不随文章滚动，支持当前章节高亮和自动滚动。
 * 移动端自动转为顶部目录。
 */
---

<nav
  id="toc"
  class="hidden xl:block fixed right-4 top-24 w-64 max-h-[calc(100vh-8rem)] overflow-y-auto rounded-xl border border-border/60 bg-background/80 backdrop-blur-md p-4 shadow-lg shadow-black/5"
  aria-label="文章目录"
>
  <h3 class="mb-3 font-semibold text-accent flex items-center gap-2">
    <span class="w-1 h-4 rounded-full bg-accent"></span>
    目录
  </h3>
  <ul id="toc-list" class="space-y-1.5 text-sm"></ul>
</nav>

<nav
  id="toc-mobile"
  class="xl:hidden mb-6 rounded-xl border border-border/60 bg-muted/30 p-4"
  aria-label="文章目录"
>
  <div class="flex items-center justify-between">
    <h3 class="font-semibold text-accent flex items-center gap-2">
      <span class="w-1 h-4 rounded-full bg-accent"></span>
      目录
    </h3>
    <button
      id="toc-toggle"
      class="text-muted-foreground hover:text-accent transition-colors"
      aria-label="展开/收起目录"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5 toc-toggle-icon"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M19 9l-7 7-7-7"
        />
      </svg>
    </button>
  </div>
  <ul id="toc-list-mobile" class="mt-3 space-y-1.5 text-sm overflow-hidden"></ul>
</nav>

<script is:inline>
  function createToc() {
    var article = document.getElementById("article");
    var tocList = document.getElementById("toc-list");
    var tocListMobile = document.getElementById("toc-list-mobile");
    var toc = document.getElementById("toc");
    var tocMobile = document.getElementById("toc-mobile");

    if (!article || !tocList || !toc) return;

    var headings = article.querySelectorAll("h2, h3");
    if (headings.length === 0) {
      if (toc) toc.style.display = "none";
      if (tocMobile) tocMobile.style.display = "none";
      return;
    }

    function buildTocHtml() {
      var html = "";
      headings.forEach(function (heading) {
        var level = parseInt(heading.tagName.charAt(1));
        var id = heading.id || heading.textContent
          .trim()
          .toLowerCase()
          .replace(/[^a-z0-9\u4e00-\u9fa5]+/g, "-");
        if (!heading.id) heading.id = id;
        var title = heading.textContent.trim();
        var indent = level === 3 ? "pl-3 text-muted-foreground/80" : "";
        html += '<li class="' + indent + '"><a href="#' + id + '" class="toc-link block py-1 px-2 rounded hover:bg-muted/50 hover:text-accent transition-all duration-200">' + title + "</a></li>";
      });
      return html;
    }

    var tocHtml = buildTocHtml();
    tocList.innerHTML = tocHtml;
    if (tocListMobile) tocListMobile.innerHTML = tocHtml;

    var tocLinks = document.querySelectorAll(".toc-link");

    function highlightActiveSection() {
      var scrollPosition = window.scrollY + 120;
      var activeId = "";

      headings.forEach(function (heading) {
        var offset = heading.offsetTop;
        if (scrollPosition >= offset) {
          activeId = heading.id;
        }
      });

      tocLinks.forEach(function (link) {
        var isActive = link.getAttribute("href") === "#" + activeId;
        link.classList.toggle("font-semibold", isActive);
        link.classList.toggle("text-accent", isActive);
        link.classList.toggle("bg-muted/50", isActive);
      });

      var activeLink = document.querySelector(".toc-link.text-accent");
      if (activeLink && toc) {
        var tocRect = toc.getBoundingClientRect();
        var linkRect = activeLink.getBoundingClientRect();
        var offsetTop = activeLink.offsetTop;

        if (linkRect.top < tocRect.top + 60) {
          toc.scrollTo({ top: offsetTop - 60, behavior: "smooth" });
        } else if (linkRect.bottom > tocRect.bottom - 20) {
          toc.scrollTo({
            top: offsetTop + linkRect.height - tocRect.height + 60,
            behavior: "smooth",
          });
        }
      }
    }

    // 移除旧的 scroll 监听器（view transition 导航时避免重复绑定）
    if (window.__tocScrollHandler) {
      window.removeEventListener("scroll", window.__tocScrollHandler);
    }
    window.__tocScrollHandler = highlightActiveSection;
    window.addEventListener("scroll", highlightActiveSection, {
      passive: true,
    });
    highlightActiveSection();

    tocLinks.forEach(function (link) {
      link.addEventListener("click", function (e) {
        e.preventDefault();
        var targetId = link.getAttribute("href").substring(1);
        var target = document.getElementById(targetId);
        if (target) {
          var offsetTop = target.offsetTop - 80;
          window.scrollTo({ top: offsetTop, behavior: "smooth" });
        }
      });
    });

    var tocToggle = document.getElementById("toc-toggle");
    var tocListMobileEl = document.getElementById("toc-list-mobile");
    if (tocToggle && tocListMobileEl) {
      var isExpanded = true;
      tocToggle.onclick = function () {
        isExpanded = !isExpanded;
        tocListMobileEl.classList.toggle("max-h-96", isExpanded);
        tocListMobileEl.classList.toggle("max-h-0", !isExpanded);
        var svg = tocToggle.querySelector(".toc-toggle-icon");
        if (svg) {
          svg.style.transform = isExpanded ? "rotate(0deg)" : "rotate(180deg)";
        }
      };
      tocListMobileEl.classList.add("max-h-96");
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", createToc);
  } else {
    createToc();
  }

  // view transition 导航后重新生成目录
  document.addEventListener("astro:after-swap", createToc);
</script>
